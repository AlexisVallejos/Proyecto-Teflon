NODE_ENV=production
PORT=3010

# Must match the secret used by vase.ar to sign upload Bearer tokens.
UPLOADS_JWT_SECRET=change_me_same_as_vase_app_upload_token_secret
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=

UPLOADS_ROOT=/data/uploads
PUBLIC_BASE_URL=https://uploads.vase.ar
PUBLIC_URL_SECRET=change_me_public_link_secret

MAX_FILE_SIZE_MB=50
PUBLIC_LINK_TTL_SECONDS=604800
CORS_ORIGIN=https://vase.ar,https://editor.vase.ar
